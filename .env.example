# Copy this file to `.env` and fill in the values you need.
# `.env` is gitignored. PANOPTES loads it automatically via python-dotenv.

# ---------------------------------------------------------------------------
# Provider API keys (set the ones you intend to use; missing keys only
# error when a judge that depends on them is constructed).
# ---------------------------------------------------------------------------

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
TOGETHER_API_KEY=
GROQ_API_KEY=

# ---------------------------------------------------------------------------
# Local paths. Defaults are relative to the project working directory.
# ---------------------------------------------------------------------------

# PANOPTES_CACHE_DIR=./.panoptes-cache
# PANOPTES_RUNS_DIR=./runs

# ---------------------------------------------------------------------------
# HTTP client tuning. The defaults are sensible for most provider quotas.
# ---------------------------------------------------------------------------

# PANOPTES_REQUEST_TIMEOUT=60       # seconds
# PANOPTES_CONNECT_TIMEOUT=10       # seconds
# PANOPTES_MAX_RETRIES=5
# PANOPTES_BACKOFF_BASE=1.0         # exponential-backoff base, seconds
# PANOPTES_BACKOFF_MAX=30.0         # exponential-backoff cap, seconds
